{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/:match*",
      "destination": "/client/dist/assets/:match*"
    },
    {
      "source": "/((?!api|assets).*).:ext",
      "destination": "/client/dist/$1.:ext"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/client/dist/index.html"
    }
  ]
}
